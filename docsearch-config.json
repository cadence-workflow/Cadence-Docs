{
  "index_name": "cadenceworkflow",
  "start_urls": [
    "https://cadenceworkflow.io/"
  ],
  "sitemap_urls": [
    "https://cadenceworkflow.io/sitemap.xml"
  ],
  "sitemap_alternate_links": true,
  "stop_urls": [
    "/blog/archive",
    "/blog/authors",
    "/blog/tags",
    "/blog/page/",
    "/community/tags",
    "/faq/tags",
    "/search",
    "/markdown-page"
  ],
  "selectors": {
    "lvl0": {
      "selector": "(//ul[contains(@class,'menu__list')]//a[contains(@class,'menu__link--active')]/text() | //nav[contains(@class,'navbar')]//a[contains(@class,'navbar__link--active')]/text())[last()]",
      "type": "xpath",
      "global": true,
      "default_value": "Documentation"
    },
    "lvl1": "article h1",
    "lvl2": "article h2",
    "lvl3": "article h3",
    "lvl4": "article h4",
    "lvl5": "article h5",
    "text": "article p, article li, article td:last-child"
  },
  "selectors_exclude": [
    ".theme-admonition",
    ".table-of-contents",
    ".docusaurus-highlight-code-line"
  ],
  "custom_settings": {
    "separatorsToIndex": "_",
    "attributesForFaceting": [
      "language",
      "version",
      "type",
      "docusaurus_tag"
    ],
    "attributesToRetrieve": [
      "hierarchy",
      "content",
      "anchor",
      "url",
      "url_without_anchor",
      "type"
    ]
  },
  "min_indexed_level": 0,
  "nb_shards": 1
}
